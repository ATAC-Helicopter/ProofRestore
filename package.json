{
  "name": "proofrestore",
  "version": "0.1.0",
  "description": "Evidence-backed backup recoverability verification and safe restore simulation.",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "backup",
    "disaster-recovery",
    "openai",
    "recoverability",
    "restore-simulation"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "capture:submission": "node scripts/capture-submission-assets.mjs",
    "record:demo": "node scripts/record-demo.mjs"
  },
  "dependencies": {
    "next": "15.5.20",
    "openai": "^5.10.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.31.0",
    "eslint-config-next": "15.5.20",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
