# Optional. The complete demo works without this value.
OPENAI_API_KEY=

# Opt in explicitly before a server-side key can be used. Leave false for public demos.
ENABLE_OPENAI_INTERPRETER=false

# Optional model override for the natural-language interpreter.
OPENAI_MODEL=gpt-5.6-sol

# Optional canonical deployment URL used for social metadata.
NEXT_PUBLIC_SITE_URL=
